Content-Type: application/json

{
  "scope": "programming",
  "text": "אני מחפשת מתכון לעוגת שוקולד"
}

### ================================
### 5️⃣ יצירת AI Profile עם הקטגוריות וההגדרות
### ================================
POST http://localhost:3001/filter/ai-profiles
Content-Type: application/json

{
  "name": "programming-only-assistant",

  "allowedCategories": [
    "Core Concepts of programming",
    "Frameworks & Languages (programming)",
    "Modern Tools & AI Infrastructure (programming)",
    "Web & Infrastructure (programming)",
    "Testing & Quality Assurance (programming)",
    "Infrastructure & Cloud (AWS & DevOps)",
    "Databases & Optimization (programming)",
    "Authentication & Security (programming)",
    "Questions & Context in devellopment (programming)"
  ],

  "blockedCategories": [
    "בידור ותרבות",
    "משפחה וילדים",
    "בישול ואוכל",
    "טיולים ונופש",
    "בריאות וספורט",
    "House Maintenance & Cleaning",
    "Shopping",
    "General Life Advice",
    "Lifestyle",
    "Entertainment & Leisure",
    "Health"
  ],

  "thresholdAllowed": 0.25,
  "thresholdBlocked": 0.25,
  "similarityMargin": 0.05,

  "createdBy": "system",
  "creatorEmail": "admin@safeai.local",

  "contentPrompts": [
    "Answer only questions related to software development and programming.",
    "If the question is not related to programming, politely refuse."
  ],

  "behaviorPrompts": [
    "Respond in a professional developer tone.",
    "Provide concise technical explanations with examples when relevant."
  ],

  "knowledgePrompts": [
    "Use examples from real programming languages and frameworks.",
    "Prefer modern development practices and tools."
  ]
}

